{
  "name": "@shadow-clone/mcp-server",
  "version": "0.2.3",
  "description": "Shadow Clone MCP Server - Prompt Engineering Macro System for AI enhancement via Model Context Protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "shadow-clone-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:prod": "npm run clean && npm run build",
    "clean": "rm -rf dist",
    "convert-prompts": "node scripts/convert-prompts.js",
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "prepare": "npm run build",
    "version": "echo $npm_package_version",
    "check-updates": "npm outdated -g @shadow-clone/mcp-server",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "health": "NODE_ENV=production ENABLE_METRICS=true node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "agents",
    "orchestration",
    "shadow-clone"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "author": "Ignis AI Labs LLC",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ElijahMoses/shadow-clone.git",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/ElijahMoses/shadow-clone/issues"
  },
  "homepage": "https://github.com/ElijahMoses/shadow-clone/tree/main/mcp-server",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
