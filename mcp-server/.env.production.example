# Shadow Clone MCP Server Production Configuration
# Copy this to .env.production and update values

# Server Configuration
NODE_ENV=production
MCP_SERVER_NAME=shadow-clone-mcp
GRACEFUL_SHUTDOWN_TIMEOUT=30000

# Security Configuration
MAX_REQUEST_SIZE=1048576
MAX_STRING_LENGTH=100000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TIMESTAMP=true
LOG_MASK_SENSITIVE=true

# Performance Configuration
MAX_EXECUTION_TIME=300000
MAX_MEMORY_USAGE=524288000
ENABLE_METRICS=true

# API Configuration (for authentication)
SHADOW_CLONE_API_URL=https://api.shadowclone.ai
SHADOW_CLONE_API_TIMEOUT=30000