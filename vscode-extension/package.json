{
  "name": "shadow-clone",
  "displayName": "Shadow Clone AI Agent Orchestrator",
  "description": "Deploy teams of specialized AI agents to complete complex software projects. Currently exclusive to Ignis Elite NFT holders.",
  "version": "0.1.3",
  "publisher": "IgnisAILabsLLC",
  "private": false,
  "license": "Proprietary",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ignislabs/shadow-clone"
  },
  "homepage": "https://shadow-clone.ai",
  "bugs": {
    "url": "https://github.com/ignislabs/shadow-clone/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "agent",
    "automation",
    "shadow-clone",
    "code-generation",
    "orchestration",
    "nft",
    "ignis"
  ],
  "badges": [
    {
      "url": "https://img.shields.io/badge/license-NFT%20Exclusive-blue",
      "href": "https://shadow-clone.ai/license",
      "description": "License Type"
    },
    {
      "url": "https://img.shields.io/badge/Claude-Integration-green",
      "href": "https://claude.ai",
      "description": "Claude Integration"
    }
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shadowClone.createProject",
        "title": "Shadow Clone: Create New Project"
      },
      {
        "command": "shadowClone.deployAgents",
        "title": "Shadow Clone: Deploy AI Agents"
      },
      {
        "command": "shadowClone.showStatus",
        "title": "Shadow Clone: Show Project Status"
      },
      {
        "command": "shadowClone.authenticate",
        "title": "Shadow Clone: Authenticate"
      },
      {
        "command": "shadowClone.launchClaude",
        "title": "Shadow Clone: Launch Claude Code",
        "icon": "$(terminal)"
      },
      {
        "command": "shadowClone.buildCustomCommand",
        "title": "Shadow Clone: Build Custom Command"
      },
      {
        "command": "shadowClone.showSessions",
        "title": "Shadow Clone: Show Active Sessions"
      },
      {
        "command": "shadowClone.terminateSession",
        "title": "Shadow Clone: Terminate Session",
        "icon": "$(close)"
      },
      {
        "command": "shadowClone.clearCompletedSessions",
        "title": "Shadow Clone: Clear Completed Sessions"
      },
      {
        "command": "shadowClone.signOut",
        "title": "Shadow Clone: Sign Out",
        "icon": "$(sign-out)"
      },
      {
        "command": "shadowClone.injectCommand",
        "title": "Shadow Clone: Inject Command",
        "icon": "$(code)"
      },
      {
        "command": "shadowClone.injectDeploy",
        "title": "Shadow Clone: Inject Deploy Command",
        "icon": "$(rocket)"
      },
      {
        "command": "shadowClone.injectDebug",
        "title": "Shadow Clone: Inject Debug Command",
        "icon": "$(bug)"
      },
      {
        "command": "shadowClone.injectFeature",
        "title": "Shadow Clone: Inject Feature Command",
        "icon": "$(sparkle)"
      },
      {
        "command": "shadowClone.injectCustom",
        "title": "Shadow Clone: Inject Custom Command",
        "icon": "$(edit)"
      },
      {
        "command": "shadowClone.executeMacro",
        "title": "Shadow Clone: Execute Macro"
      },
      {
        "command": "shadowClone.showHelp",
        "title": "Shadow Clone: Show Help",
        "icon": "$(question)"
      },
      {
        "command": "shadowClone.showQuickReference",
        "title": "Shadow Clone: Quick Reference",
        "icon": "$(info)"
      },
      {
        "command": "shadowClone.buildParameters",
        "title": "Shadow Clone: Build Parameters",
        "icon": "$(settings-gear)"
      },
      {
        "command": "shadowClone.paramSnippet.minimal",
        "title": "Shadow Clone: Insert Minimal Parameters"
      },
      {
        "command": "shadowClone.paramSnippet.standard",
        "title": "Shadow Clone: Insert Standard Parameters"
      },
      {
        "command": "shadowClone.paramSnippet.fullstack",
        "title": "Shadow Clone: Insert Full-Stack Parameters"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shadowClone",
          "title": "Shadow Clone",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "shadowClone": [
        {
          "id": "shadowClone.projectView",
          "name": "Projects",
          "icon": "$(project)",
          "contextualTitle": "Shadow Clone Projects"
        },
        {
          "id": "shadowClone.agentView",
          "name": "Active Agents",
          "icon": "$(account)",
          "contextualTitle": "Shadow Clone Agents"
        },
        {
          "id": "shadowClone.claudeSessions",
          "name": "Claude Sessions",
          "icon": "$(terminal)",
          "contextualTitle": "Shadow Clone Claude Sessions"
        },
        {
          "id": "shadowClone.macros",
          "name": "Macros",
          "icon": "$(code)",
          "contextualTitle": "Shadow Clone Macros"
        }
      ]
    },
    "configuration": {
      "title": "Shadow Clone",
      "properties": {
        "shadowClone.apiEndpoint": {
          "type": "string",
          "default": "https://shadow-clone-api.elijah-02b.workers.dev",
          "description": "Shadow Clone API endpoint. Set this to your Cloudflare Worker URL (e.g., https://shadow-clone.your-subdomain.workers.dev)"
        },
        "shadowClone.wavesDirectory": {
          "type": "string",
          "default": ".waves",
          "description": "Directory for agent deliverables"
        },
        "shadowClone.maxAgentsPerWave": {
          "type": "number",
          "default": 10,
          "description": "Maximum agents to deploy per wave"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "shadowClone.createProject",
          "when": "view == shadowClone.projectView",
          "group": "navigation"
        },
        {
          "command": "shadowClone.launchClaude",
          "when": "view == shadowClone.claudeSessions",
          "group": "navigation"
        },
        {
          "command": "shadowClone.showHelp",
          "when": "view == shadowClone.macros",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "shadowClone.terminateSession",
          "when": "view == shadowClone.claudeSessions && viewItem == session",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "shadowClone.injectCommand",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorTextFocus"
      },
      {
        "command": "shadowClone.injectDeploy",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "shadowClone.injectFeature",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:dev": "webpack --mode development",
    "build:prod": "NODE_ENV=production webpack --mode production",
    "build:analyze": "webpack --mode production --analyze",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:prod": "npm run build:prod && npm run test",
    "package": "vsce package",
    "package:prod": "npm run build:prod && vsce package",
    "publish": "vsce publish",
    "verify:obfuscation": "node scripts/verify-obfuscation.js"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "cors": "^2.8.5",
    "eslint": "^8.28.0",
    "express": "^4.18.2",
    "terser-webpack-plugin": "^5.3.9",
    "ts-loader": "^9.5.0",
    "typescript": "^5.1.3",
    "vsce": "^2.15.0",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.9.1",
    "webpack-cli": "^5.1.4",
    "webpack-obfuscator": "^3.5.1"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  }
}
