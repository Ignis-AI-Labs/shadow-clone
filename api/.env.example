# Shadow Clone API Environment Variables

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Development Mode
# Set to 'true' to enable dev API keys (sc-dev-*)
DEV_MODE=true

# NFT Contract Addresses (for ownership verification)
# IGNIS_ELITE_CONTRACT=0x...
# PIONEER_CONTRACT=0x...
# BUILDER_CONTRACT=0x...
# RESERVE_CONTRACT=0x...

# RPC Endpoint for blockchain calls
# ETH_RPC_URL=https://mainnet.infura.io/v3/your-key
