# Shadow Clone System .gitignore

# Runtime directories
.waves/
.backup/

# Local development (creator mode, local configs)
.shadow-local/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# Build outputs
build/
dist/
*.egg-info/
.eggs/

# Testing
.coverage
.pytest_cache/
htmlcov/
.tox/
coverage.xml
*.cover
# Internal testing files (DO NOT COMMIT)
.shadow/testing/

# Logs
*.log
logs/

# Environment files
.env
.env.local
.env.*.local

# Security
*.key
*.pem
*.cert
*.crt
secrets/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Cache
.cache/
*.cache

# Database
*.db
*.sqlite
*.sqlite3

# OS files
Thumbs.db
ehthumbs.db

# Project specific
instance/
.webassets-cache

# Documentation builds
docs/_build/
site/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Credentials
credentials.json
token.json

# Local configuration overrides
*.local
config.local.json
settings.local.json